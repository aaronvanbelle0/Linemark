# =================================================================
# LineMark Striping - .htaccess
# https://lmstriping.com
# =================================================================

# --- MIME Types ---
# Required for browsers to correctly render .avif and .webp images
AddType image/avif .avif
AddType image/webp .webp

# --- Rewrite Rules ---
RewriteEngine On

# Force HTTPS + remove www (single 301 hop)
# Handles: http→https, www→non-www, or both at once
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.lmstriping\.com [NC]
RewriteRule ^(.*)$ https://lmstriping.com/$1 [R=301,L]

# --- Security Headers ---
# Prevents clickjacking and MIME sniffing attacks
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-Content-Type-Options "nosniff"

# --- Browser Caching ---
# Tells browsers to cache static assets locally for faster repeat visits
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# --- Compression ---
# Compresses HTML, CSS, JS for faster load times
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>

# --- Error Pages ---
ErrorDocument 404 /404.html
